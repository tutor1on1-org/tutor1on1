org.gradle.jvmargs=-Xmx8G -XX:MaxMetaspaceSize=4G -XX:ReservedCodeCacheSize=512m -XX:+HeapDumpOnOutOfMemoryError -Dfile.encoding=UTF-8 -Dsun.jnu.encoding=UTF-8
org.gradle.parallel=false
org.gradle.workers.max=1
android.useAndroidX=true
android.enableAapt2VerboseLogs=true
android.enableAapt2Daemon=false

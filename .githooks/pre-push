#!/usr/bin/env bash
set -euo pipefail

if [[ "${FT_SKIP_PRE_PUSH_VALIDATE:-}" == "1" ]]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"

if command -v pwsh >/dev/null 2>&1; then
  ps_cmd="pwsh"
elif command -v powershell >/dev/null 2>&1; then
  ps_cmd="powershell"
else
  echo "PowerShell executable not found; cannot run project validation."
  exit 1
fi

memory_files=(
  "AGENTS.md"
  "README.md"
  "WORKFLOW.md"
  "SCRIPTS.md"
  "BUGS.md"
  "TODOS.md"
  "LOGBOOK.md"
  "WORKLOG.md"
  "PLANS.md"
  "DONEs.md"
  "BACKUP_DRILL.md"
  "scripts/memory_line_snapshot.json"
)

"${ps_cmd}" -NoProfile -ExecutionPolicy Bypass -File "${repo_root}/scripts/hook_memory_update.ps1" -SkipGitOps

memory_status="$(git status --porcelain -- "${memory_files[@]}")"
if [[ -n "${memory_status}" ]]; then
  echo "Memory hook generated updates. Commit these files before pushing:"
  echo "${memory_status}"
  exit 1
fi

"${ps_cmd}" -NoProfile -ExecutionPolicy Bypass -File "${repo_root}/scripts/validate_project.ps1" -NoPostHook

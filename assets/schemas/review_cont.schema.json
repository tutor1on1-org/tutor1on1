{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewContOutput",
  "type": "object",
  "required": [
    "teacher_message",
    "control",
    "answer_state",
    "difficulty_action",
    "recommended_level",
    "grading",
    "error_book_update",
    "evidence",
    "mastery_level"
  ],
  "properties": {
    "teacher_message": {
      "type": "string",
      "minLength": 1
    },
    "control": {
      "type": "object",
      "required": [
        "version",
        "mode",
        "step",
        "turn_finished",
        "help_bias",
        "allowed_actions",
        "recommended_action"
      ],
      "properties": {
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "mode": {
          "type": "string",
          "enum": ["LEARN", "REVIEW"]
        },
        "step": {
          "type": "string",
          "enum": ["NEW", "CONTINUE"]
        },
        "turn_finished": {
          "type": "boolean"
        },
        "help_bias": {
          "type": "string",
          "enum": ["EASIER", "UNCHANGED", "HARDER"]
        },
        "allowed_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "NEXT_QUESTION",
              "LEARN",
              "CONTINUE_LEARNING",
              "TRY_QUESTION",
              "SUMMARIZE",
              "PAUSE"
            ]
          },
          "uniqueItems": true
        },
        "recommended_action": {
          "type": ["string", "null"],
          "enum": [
            "NEXT_QUESTION",
            "LEARN",
            "CONTINUE_LEARNING",
            "TRY_QUESTION",
            "SUMMARIZE",
            "PAUSE",
            null
          ]
        }
      },
      "additionalProperties": false
    },
    "answer_state": {
      "type": "string",
      "enum": ["HELP_REQUEST", "PARTIAL_ATTEMPT", "FINAL_ANSWER"]
    },
    "difficulty_action": {
      "type": "string",
      "enum": ["DOWN", "HOLD", "UP"]
    },
    "recommended_level": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "grading": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": ["is_correct", "mistake_summary", "hint_level"],
          "properties": {
            "is_correct": {
              "type": "boolean"
            },
            "mistake_summary": {
              "type": "string"
            },
            "hint_level": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "error_book_update": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": ["type_id", "delta_wrong", "mistake_tag", "mistake_note"],
          "properties": {
            "type_id": {
              "type": "string",
              "minLength": 1
            },
            "delta_wrong": {
              "type": "integer",
              "minimum": 1
            },
            "mistake_tag": {
              "type": "string",
              "minLength": 1
            },
            "mistake_note": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "evidence": {
      "type": "object",
      "required": ["a", "c", "h", "t", "mt"],
      "properties": {
        "a": {
          "type": "integer",
          "minimum": 0
        },
        "c": {
          "type": "integer",
          "minimum": 0
        },
        "h": {
          "type": "integer",
          "minimum": 0
        },
        "t": {
          "type": "string"
        },
        "mt": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "mastery_level": {
      "type": "string",
      "enum": ["NOT_PASS", "PASS_EASY", "PASS_MEDIUM", "PASS_HARD"]
    }
  },
  "additionalProperties": false
}

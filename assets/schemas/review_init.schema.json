{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewInitOutput",
  "type": "object",
  "required": [
    "teacher_message",
    "control",
    "difficulty_level",
    "grading",
    "error_book_update",
    "evidence",
    "mastery_level"
  ],
  "properties": {
    "teacher_message": {
      "type": "string",
      "minLength": 1
    },
    "control": {
      "type": "object",
      "required": [
        "version",
        "mode",
        "step",
        "turn_finished",
        "help_bias",
        "allowed_actions",
        "recommended_action"
      ],
      "properties": {
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "mode": {
          "type": "string",
          "enum": ["LEARN", "REVIEW"]
        },
        "step": {
          "type": "string",
          "enum": ["NEW", "CONTINUE"]
        },
        "turn_finished": {
          "type": "boolean"
        },
        "help_bias": {
          "type": "string",
          "enum": ["EASIER", "UNCHANGED", "HARDER"]
        },
        "allowed_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "NEXT_QUESTION",
              "LEARN",
              "CONTINUE_LEARNING",
              "TRY_QUESTION",
              "SUMMARIZE",
              "PAUSE"
            ]
          },
          "uniqueItems": true
        },
        "recommended_action": {
          "type": ["string", "null"],
          "enum": [
            "NEXT_QUESTION",
            "LEARN",
            "CONTINUE_LEARNING",
            "TRY_QUESTION",
            "SUMMARIZE",
            "PAUSE",
            null
          ]
        }
      },
      "additionalProperties": false
    },
    "difficulty_level": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "grading": {
      "type": "null"
    },
    "error_book_update": {
      "type": "null"
    },
    "evidence": {
      "type": "object",
      "required": ["a", "c", "h", "t", "mt"],
      "properties": {
        "a": {
          "type": "integer",
          "minimum": 0
        },
        "c": {
          "type": "integer",
          "minimum": 0
        },
        "h": {
          "type": "integer",
          "minimum": 0
        },
        "t": {
          "type": "string",
          "minLength": 1
        },
        "mt": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "mastery_level": {
      "type": "string",
      "enum": ["NOT_PASS", "PASS_EASY", "PASS_MEDIUM", "PASS_HARD"]
    }
  },
  "additionalProperties": false
}

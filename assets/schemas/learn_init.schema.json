{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LearnInitOutput",
  "type": "object",
  "required": [
    "teacher_message",
    "understanding",
    "control"
  ],
  "properties": {
    "teacher_message": {
      "type": "string",
      "minLength": 1
    },
    "understanding": {
      "type": "string",
      "enum": ["CONFUSED", "PARTIAL", "READY"]
    },
    "control": {
      "type": "object",
      "required": [
        "version",
        "mode",
        "step",
        "turn_finished",
        "help_bias",
        "allowed_actions",
        "recommended_action"
      ],
      "properties": {
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "mode": {
          "type": "string",
          "enum": ["LEARN", "REVIEW"]
        },
        "step": {
          "type": "string",
          "enum": ["NEW", "CONTINUE"]
        },
        "turn_finished": {
          "type": "boolean"
        },
        "help_bias": {
          "type": "string",
          "enum": ["EASIER", "UNCHANGED", "HARDER"]
        },
        "allowed_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "NEXT_QUESTION",
              "LEARN",
              "CONTINUE_LEARNING",
              "TRY_QUESTION",
              "SUMMARIZE",
              "PAUSE"
            ]
          },
          "uniqueItems": true
        },
        "recommended_action": {
          "type": ["string", "null"],
          "enum": [
            "NEXT_QUESTION",
            "LEARN",
            "CONTINUE_LEARNING",
            "TRY_QUESTION",
            "SUMMARIZE",
            "PAUSE",
            null
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

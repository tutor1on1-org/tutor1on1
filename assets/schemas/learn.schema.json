{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LearnOutput",
  "type": "object",
  "required": [
    "text",
    "difficulty",
    "mistakes",
    "next_action"
  ],
  "properties": {
    "text": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "mistakes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_action": {
      "type": "string",
      "enum": ["learn", "review"]
    }
  },
  "additionalProperties": false
}
